<?xml version="1.0" encoding="UTF-8"?>
<!-- Rebuild this file completely for each new site. All URLs are site-specific. -->
<!-- Replace <!-- DOMAIN --> with the site's domain (no trailing slash). -->
<!-- Update <lastmod> dates to the actual publication/update date of each page. -->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- ROOT -->
  <url>
    <loc>https://<!-- DOMAIN -->/</loc>
    <lastmod><!-- YYYY-MM-DD --></lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://<!-- DOMAIN -->/why/</loc>
    <lastmod><!-- YYYY-MM-DD --></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
