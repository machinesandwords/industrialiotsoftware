    <loc>https://<!-- DOMAIN -->/subscribe/</loc>
    <lastmod><!-- YYYY-MM-DD --></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>

  <!-- LANDSCAPE -->
  <url>
    <loc>https://<!-- DOMAIN -->/landscape/</loc>
    <lastmod><!-- YYYY-MM-DD --></lastmod>
    <changefreq>monthly</changefreq>
